{
  "name": "amaechler.com",
  "type": "module",
  "version": "1.0.0",
  "description": "Personal blog powered by Astro and Markdown",
  "author": "Andreas Maechler <amaechler@gmail.com>",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && shx echo 'amaechler.com' > dist/CNAME",
    "preview": "astro preview",
    "deploy": "astro build && shx echo 'amaechler.com' > dist/CNAME && gh-pages -d dist",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/montserrat": "^5.2.8",
    "astro": "^6.3.8",
    "gh-pages": "^6.3.0",
    "normalize.css": "^8.0.1",
    "remark-smartypants": "^3.0.2",
    "shx": "^0.4.0"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
