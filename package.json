    "validate": "pnpm format:check && pnpm build",
    "astro": "astro",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/montserrat": "^5.2.8",
    "astro": "^6.3.8",
    "normalize.css": "^8.0.1",
    "remark-smartypants": "^3.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "lefthook": "^2.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  }
