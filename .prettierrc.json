{
  "plugins": ["prettier-plugin-astro"],
  "arrowParens": "avoid",
  "endOfLine": "auto",
  "printWidth": 120,
  "quoteProps": "preserve",
  "tabWidth": 4,
  "trailingComma": "none",
  "overrides": [
    {
      "files": "*.astro",
      "options": { "parser": "astro" }
    },
    {
      "files": ["*.json", "*.jsonc", "*.json5", "*.yml", "*.yaml"],
      "options": { "tabWidth": 2 }
    }
  ]
}
