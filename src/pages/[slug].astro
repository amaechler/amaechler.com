---
import Layout from '../layouts/Layout.astro';
import Bio from '../components/Bio.astro';
import { getCollection } from 'astro:content';

interface EntryProps {
  post: import('astro:content').CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => {
    const slug = post.id.replace(/^blog\//, '');
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props as EntryProps;
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const currentSlug = Astro.params.slug;
const currentIndex = sortedPosts.findIndex(p => p.id.replace(/^blog\//, '') === currentSlug);
const prev = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const next = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const dateFormatted = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.date);
const slug = post.id.replace(/^blog\//, '');

---
<Layout title={post.data.title}>
  <article class="blog-post" itemScope itemType="http://schema.org/Article">
    <header>
      <h1 itemProp="headline">{post.data.title}</h1>
      <p>{dateFormatted}</p>
    </header>
    <section>{post.body}</section>
    <hr />
    <footer>
      <Bio />
    </footer>
  </article>
  <nav class="blog-post-nav">
    <ul style="display: flex; flex-wrap: wrap; justify-content: space-between; list-style: none; padding: 0;">
      <li>
        {prev && (
          <a href={`/${prev.id.replace(/^blog\//, '')}`} rel="prev">
            {"\u2190"} {prev.data.title}
          </a>
        )}
      </li>
      <li>
        {next && (
          <a href={`/${next.id.replace(/^blog\//, '')}`} rel="next">
            {next.data.title} {"\u2192"}
          </a>
        )}
      </li>
    </ul>
  </nav>
</Layout>
